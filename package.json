{
  "name": "aeronotes",
  "version": "0.1.0",
  "description": "AeroNotes - sticky notes avancees avec support Markdown, dock repositionnable et notes detachables",
  "main": "./out/main/index.js",
  "author": "julien.kopoin@gmail.com",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
